// router_pi.json5 -- config ROUTER Zenoh pentru Raspberry Pi (pi4-node), HIL Wi-Fi C1.
// Interfata wlan0, IP 192.168.100.19. Asculta pe .19; M1 se conecteaza la el.
// Folosit cu: export ZENOH_ROUTER_CONFIG_URI=router_pi.json5 ; ros2 run rmw_zenoh_cpp rmw_zenohd
{
  mode: "router",
  connect: { endpoints: [] },
  listen: { endpoints: ["tcp/[::]:7447"] },
  scouting: {
    multicast: { enabled: false }
  }
}
