// router_m1.json5 -- config ROUTER Zenoh pentru laptopul M1 (masina-client), HIL Wi-Fi C1.
// Interfata wlp4s0, IP 192.168.100.14. Asculta pe .14; se conecteaza la routerul Pi (.19).
// Folosit cu: export ZENOH_ROUTER_CONFIG_URI=router_m1.json5 ; ros2 run rmw_zenoh_cpp rmw_zenohd
{
  mode: "router",
  connect: { endpoints: ["tcp/192.168.100.19:7447"] },
  listen: { endpoints: ["tcp/192.168.100.14:7447"] },
  scouting: {
    multicast: { enabled: false }
  }
}
