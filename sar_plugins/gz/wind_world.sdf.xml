<!-- wind_world.sdf.xml — vant in lume (gz::sim::systems::WindEffects).

  Se lipeste in interiorul <world>. IMPORTANT: vantul afecteaza DOAR
  link-urile care au explicit:
      <link name="..."> ... <enable_wind>true</enable_wind> ... </link>
  (adauga linia in link-urile dronei / sasiul roverului).

  Configuratia de mai jos: vant mediu 5 m/s pe directia initiala +X,
  cu fluctuatii lente de amplitudine (~banda 0.1-0.6 Hz) si oscilatii
  de directie de +/-30 grade — suficient cat sa perturbe vizibil
  multicopterul si sa motiveze controlul robust, fara sa-l doboare.

  Pentru rafale dure in scenariul "furtuna": creste <magnitude><mean>
  la 9-10 si sin/amplitude_percent la 0.6.
-->
<plugin filename="gz-sim-wind-effects-system"
        name="gz::sim::systems::WindEffects">
  <force_approximation_scaling_factor>1.0</force_approximation_scaling_factor>
  <horizontal>
    <magnitude>
      <time_for_rise>10</time_for_rise>
      <sin>
        <amplitude_percent>0.35</amplitude_percent>
        <period>12</period>
      </sin>
      <noise type="gaussian">
        <mean>0</mean>
        <stddev>0.6</stddev>
      </noise>
    </magnitude>
    <direction>
      <time_for_rise>30</time_for_rise>
      <sin>
        <amplitude>30</amplitude>
        <period>25</period>
      </sin>
      <noise type="gaussian">
        <mean>0</mean>
        <stddev>3</stddev>
      </noise>
    </direction>
  </horizontal>
  <vertical>
    <noise type="gaussian">
      <mean>0</mean>
      <stddev>0.15</stddev>
    </noise>
  </vertical>
</plugin>
