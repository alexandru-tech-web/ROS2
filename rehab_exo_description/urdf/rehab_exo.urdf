<?xml version="1.0"?>
<!-- Sistem de reabilitare v2: scaun medical + pacient integrat +
     picioare mecanice 6 GDL. Conform Fig 2.2 din documentul-sursa:
     001=baza sezut, 002=sezut, 003=baza picior mecanic, 007=picior mecanic.
     Postura zero = SEZUT. Generat parametric; verificat prin FK. -->
<robot name="rehab_exo">

  <material name="frame_gri"><color rgba="0.35 0.36 0.38 1.0"/></material>
  <material name="cushion"><color rgba="0.13 0.17 0.32 1.0"/></material>
  <material name="mech_left"><color rgba="0.20 0.45 0.80 1.0"/></material>
  <material name="mech_right"><color rgba="0.85 0.40 0.18 1.0"/></material>
  <material name="skin"><color rgba="0.88 0.72 0.58 1.0"/></material>
  <material name="cloth"><color rgba="0.18 0.42 0.40 1.0"/></material>
  <material name="pants"><color rgba="0.25 0.25 0.28 1.0"/></material>
  <material name="shoe"><color rgba="0.10 0.10 0.10 1.0"/></material>

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/><child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.0000 0.0000 0.0600" rpy="0 0 0"/>
      <mass value="22.000"/>
      <inertia ixx="0.678333" ixy="0" ixz="0" iyy="0.916667" iyz="0" izz="1.558333"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <geometry><box size="0.7000 0.6000 0.1000"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="-0.1000 0.0000 0.3000" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.1600 0.4000"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <geometry><box size="0.7000 0.6000 0.1000"/></geometry>
    </collision>
  </link>

  <!-- v3: ridicarea/coborarea scaunului fata de baza (ajustare pacient) -->
  <joint name="seat_lift_joint" type="prismatic">
    <parent link="base_link"/><child link="seat_link"/>
    <origin xyz="0 0 0.485" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.15" effort="500.0" velocity="0.05"/>
    <dynamics damping="50.0" friction="5.0"/>
  </joint>
  <link name="seat_link">
    <inertial>
      <origin xyz="0.0000 0.0000 0.0000" rpy="0 0 0"/>
      <mass value="9.000"/>
      <inertia ixx="0.162375" ixy="0" ixz="0" iyy="0.162375" iyz="0" izz="0.317400"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.4600 0.4600 0.0700"/></geometry>
      <material name="cushion"/>
    </visual>
    <visual>
      <origin xyz="0.0200 0.2950 0.2150" rpy="0 0 0"/>
      <geometry><box size="0.3400 0.0600 0.0400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.0200 -0.2950 0.2150" rpy="0 0 0"/>
      <geometry><box size="0.3400 0.0600 0.0400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="-0.1000 0.2950 0.1050" rpy="0 0 0"/>
      <geometry><box size="0.0500 0.0500 0.1800"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="-0.1000 -0.2950 0.1050" rpy="0 0 0"/>
      <geometry><box size="0.0500 0.0500 0.1800"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.1600 0.3050 -0.1300" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.0800 0.2400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.1600 -0.3050 -0.1300" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.0800 0.2400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.4600 0.4600 0.0700"/></geometry>
    </collision>
  </link>

  <joint name="seat_to_back" type="fixed">
    <parent link="seat_link"/><child link="backrest_link"/>
    <origin xyz="-0.235 0 0.02" rpy="0 -0.21 0"/>
  </joint>
  <link name="backrest_link">
    <inertial>
      <origin xyz="0.0000 0.0000 0.3000" rpy="0 0 0"/>
      <mass value="6.000"/>
      <inertia ixx="0.274000" ixy="0" ixz="0" iyy="0.170650" iyz="0" izz="0.108250"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 0.3000" rpy="0 0 0"/>
      <geometry><box size="0.0700 0.4600 0.5800"/></geometry>
      <material name="cushion"/>
    </visual>
    <visual>
      <origin xyz="0.0000 0.0000 0.6600" rpy="0 0 0"/>
      <geometry><box size="0.0600 0.2600 0.1400"/></geometry>
      <material name="cushion"/>
    </visual>
    <visual>
      <origin xyz="-0.0500 0.0000 0.6200" rpy="0 0 0"/>
      <geometry><box size="0.0400 0.5000 0.0400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 0.3000" rpy="0 0 0"/>
      <geometry><box size="0.0700 0.4600 0.5800"/></geometry>
    </collision>
  </link>

  <joint name="seat_to_human" type="fixed">
    <parent link="seat_link"/><child link="human_torso"/>
    <origin xyz="-0.04 0 0.035" rpy="0 0 0"/>
  </joint>
  <link name="human_torso">
    <inertial>
      <origin xyz="0.0000 0.0000 0.2800" rpy="0 0 0"/>
      <mass value="32.000"/>
      <inertia ixx="1.029333" ixy="0" ixz="0" iyy="0.874667" iyz="0" izz="0.461867"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 0.2800" rpy="0 0 0"/>
      <geometry><box size="0.2400 0.3400 0.5200"/></geometry>
      <material name="cloth"/>
    </visual>
    <visual>
      <origin xyz="0.0100 0.0000 0.6650" rpy="0 0 0"/>
      <geometry><sphere radius="0.1050"/></geometry>
      <material name="skin"/>
    </visual>
    <visual>
      <origin xyz="0.0100 0.0000 0.5550" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0450" length="0.0700"/></geometry>
      <material name="skin"/>
    </visual>
    <visual>
      <origin xyz="0.0000 0.2050 0.4000" rpy="0.15 0 0"/>
      <geometry><cylinder radius="0.0450" length="0.2600"/></geometry>
      <material name="cloth"/>
    </visual>
    <visual>
      <origin xyz="0.0000 -0.2050 0.4000" rpy="-0.15 0 0"/>
      <geometry><cylinder radius="0.0450" length="0.2600"/></geometry>
      <material name="cloth"/>
    </visual>
    <visual>
      <origin xyz="0.1300 0.2350 0.2350" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0400" length="0.2400"/></geometry>
      <material name="skin"/>
    </visual>
    <visual>
      <origin xyz="0.1300 -0.2350 0.2350" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0400" length="0.2400"/></geometry>
      <material name="skin"/>
    </visual>
    <visual>
      <origin xyz="0.2600 0.2350 0.2350" rpy="0 0 0"/>
      <geometry><sphere radius="0.0450"/></geometry>
      <material name="skin"/>
    </visual>
    <visual>
      <origin xyz="0.2600 -0.2350 0.2350" rpy="0 0 0"/>
      <geometry><sphere radius="0.0450"/></geometry>
      <material name="skin"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 0.2800" rpy="0 0 0"/>
      <geometry><box size="0.2400 0.3400 0.5200"/></geometry>
    </collision>
  </link>

  <!-- ============ Piciorul left (mecanic 007 + membru uman) ============ -->
  <joint name="left_hip_joint" type="revolute">
    <parent link="seat_link"/><child link="left_thigh"/>
    <origin xyz="0.160 0.260 0.035" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.45" upper="0.7" effort="120.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <link name="left_thigh">
    <inertial>
      <origin xyz="0.2000 -0.0575 0.0000" rpy="0 0 0"/>
      <mass value="6.500"/>
      <inertia ixx="0.019283" ixy="0" ixz="0" iyy="0.092083" iyz="0" izz="0.100533"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0550 0.0000" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0850" length="0.1000"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.2000 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.4000 0.0500 0.0700"/></geometry>
      <material name="mech_left"/>
    </visual>
    <visual>
      <origin xyz="0.2000 -0.1150 0.0000" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0720" length="0.3800"/></geometry>
      <material name="pants"/>
    </visual>
    <collision>
      <origin xyz="0.2000 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.4000 0.0600 0.0800"/></geometry>
    </collision>
  </link>
  <joint name="left_thigh_ext_joint" type="prismatic">
    <parent link="left_thigh"/><child link="left_thigh_ext"/>
    <origin xyz="0.400 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.08" effort="300.0" velocity="0.03"/>
    <dynamics damping="30.0" friction="3.0"/>
  </joint>
  <link name="left_thigh_ext">
    <inertial>
      <origin xyz="-0.0500 0.0000 0.0000" rpy="0 0 0"/>
      <mass value="0.800"/>
      <inertia ixx="0.000273" ixy="0" ixz="0" iyy="0.001873" iyz="0" izz="0.001813"/>
    </inertial>
    <visual>
      <origin xyz="-0.0500 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.0380 0.0550"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.0000 0.0400 0.0000" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0600" length="0.0800"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="-0.0500 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.0400 0.0600"/></geometry>
    </collision>
  </link>
  <joint name="left_knee_joint" type="revolute">
    <parent link="left_thigh_ext"/><child link="left_shank"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="1.75" effort="120.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <link name="left_shank">
    <inertial>
      <origin xyz="0.0000 -0.0575 -0.2000" rpy="0 0 0"/>
      <mass value="4.000"/>
      <inertia ixx="0.059867" ixy="0" ixz="0" iyy="0.054967" iyz="0" izz="0.008167"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 -0.2000" rpy="0 0 0"/>
      <geometry><box size="0.0500 0.0450 0.4000"/></geometry>
      <material name="mech_left"/>
    </visual>
    <visual>
      <origin xyz="0.0000 -0.1150 -0.2000" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0580" length="0.3800"/></geometry>
      <material name="pants"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 -0.2000" rpy="0 0 0"/>
      <geometry><box size="0.0600 0.0500 0.4000"/></geometry>
    </collision>
  </link>
  <joint name="left_shank_ext_joint" type="prismatic">
    <parent link="left_shank"/><child link="left_shank_ext"/>
    <origin xyz="0 0 -0.400" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.08" effort="300.0" velocity="0.03"/>
    <dynamics damping="30.0" friction="3.0"/>
  </joint>
  <link name="left_shank_ext">
    <inertial>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <mass value="0.600"/>
      <inertia ixx="0.001060" ixy="0" ixz="0" iyy="0.001060" iyz="0" izz="0.000160"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <geometry><box size="0.0380 0.0340 0.1400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <geometry><box size="0.0400 0.0400 0.1400"/></geometry>
    </collision>
  </link>
  <joint name="left_ankle_joint" type="revolute">
    <parent link="left_shank_ext"/><child link="left_foot"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.6" upper="0.6" effort="120.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <link name="left_foot">
    <inertial>
      <origin xyz="0.0700 -0.0575 -0.0400" rpy="0 0 0"/>
      <mass value="1.200"/>
      <inertia ixx="0.002050" ixy="0" ixz="0" iyy="0.005850" iyz="0" izz="0.007720"/>
    </inertial>
    <visual>
      <origin xyz="0.0700 0.0000 -0.0550" rpy="0 0 0"/>
      <geometry><box size="0.2400 0.1300 0.0250"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.0750 -0.1150 -0.0200" rpy="0 0 0"/>
      <geometry><box size="0.2300 0.0850 0.0550"/></geometry>
      <material name="shoe"/>
    </visual>
    <collision>
      <origin xyz="0.0700 0.0000 -0.0550" rpy="0 0 0"/>
      <geometry><box size="0.2400 0.1400 0.0300"/></geometry>
    </collision>
  </link>

  <!-- ============ Piciorul right (mecanic 007 + membru uman) ============ -->
  <joint name="right_hip_joint" type="revolute">
    <parent link="seat_link"/><child link="right_thigh"/>
    <origin xyz="0.160 -0.260 0.035" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.45" upper="0.7" effort="120.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <link name="right_thigh">
    <inertial>
      <origin xyz="0.2000 0.0575 0.0000" rpy="0 0 0"/>
      <mass value="6.500"/>
      <inertia ixx="0.019283" ixy="0" ixz="0" iyy="0.092083" iyz="0" izz="0.100533"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 -0.0550 0.0000" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0850" length="0.1000"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.2000 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.4000 0.0500 0.0700"/></geometry>
      <material name="mech_right"/>
    </visual>
    <visual>
      <origin xyz="0.2000 0.1150 0.0000" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0720" length="0.3800"/></geometry>
      <material name="pants"/>
    </visual>
    <collision>
      <origin xyz="0.2000 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.4000 0.0600 0.0800"/></geometry>
    </collision>
  </link>
  <joint name="right_thigh_ext_joint" type="prismatic">
    <parent link="right_thigh"/><child link="right_thigh_ext"/>
    <origin xyz="0.400 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.08" effort="300.0" velocity="0.03"/>
    <dynamics damping="30.0" friction="3.0"/>
  </joint>
  <link name="right_thigh_ext">
    <inertial>
      <origin xyz="-0.0500 0.0000 0.0000" rpy="0 0 0"/>
      <mass value="0.800"/>
      <inertia ixx="0.000273" ixy="0" ixz="0" iyy="0.001873" iyz="0" izz="0.001813"/>
    </inertial>
    <visual>
      <origin xyz="-0.0500 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.0380 0.0550"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.0000 -0.0400 0.0000" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0600" length="0.0800"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="-0.0500 0.0000 0.0000" rpy="0 0 0"/>
      <geometry><box size="0.1600 0.0400 0.0600"/></geometry>
    </collision>
  </link>
  <joint name="right_knee_joint" type="revolute">
    <parent link="right_thigh_ext"/><child link="right_shank"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="1.75" effort="120.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <link name="right_shank">
    <inertial>
      <origin xyz="0.0000 0.0575 -0.2000" rpy="0 0 0"/>
      <mass value="4.000"/>
      <inertia ixx="0.059867" ixy="0" ixz="0" iyy="0.054967" iyz="0" izz="0.008167"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 -0.2000" rpy="0 0 0"/>
      <geometry><box size="0.0500 0.0450 0.4000"/></geometry>
      <material name="mech_right"/>
    </visual>
    <visual>
      <origin xyz="0.0000 0.1150 -0.2000" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0580" length="0.3800"/></geometry>
      <material name="pants"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 -0.2000" rpy="0 0 0"/>
      <geometry><box size="0.0600 0.0500 0.4000"/></geometry>
    </collision>
  </link>
  <joint name="right_shank_ext_joint" type="prismatic">
    <parent link="right_shank"/><child link="right_shank_ext"/>
    <origin xyz="0 0 -0.400" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.08" effort="300.0" velocity="0.03"/>
    <dynamics damping="30.0" friction="3.0"/>
  </joint>
  <link name="right_shank_ext">
    <inertial>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <mass value="0.600"/>
      <inertia ixx="0.001060" ixy="0" ixz="0" iyy="0.001060" iyz="0" izz="0.000160"/>
    </inertial>
    <visual>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <geometry><box size="0.0380 0.0340 0.1400"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <collision>
      <origin xyz="0.0000 0.0000 0.0500" rpy="0 0 0"/>
      <geometry><box size="0.0400 0.0400 0.1400"/></geometry>
    </collision>
  </link>
  <joint name="right_ankle_joint" type="revolute">
    <parent link="right_shank_ext"/><child link="right_foot"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-0.6" upper="0.6" effort="120.0" velocity="2.0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>
  <link name="right_foot">
    <inertial>
      <origin xyz="0.0700 0.0575 -0.0400" rpy="0 0 0"/>
      <mass value="1.200"/>
      <inertia ixx="0.002050" ixy="0" ixz="0" iyy="0.005850" iyz="0" izz="0.007720"/>
    </inertial>
    <visual>
      <origin xyz="0.0700 0.0000 -0.0550" rpy="0 0 0"/>
      <geometry><box size="0.2400 0.1300 0.0250"/></geometry>
      <material name="frame_gri"/>
    </visual>
    <visual>
      <origin xyz="0.0750 0.1150 -0.0200" rpy="0 0 0"/>
      <geometry><box size="0.2300 0.0850 0.0550"/></geometry>
      <material name="shoe"/>
    </visual>
    <collision>
      <origin xyz="0.0700 0.0000 -0.0550" rpy="0 0 0"/>
      <geometry><box size="0.2400 0.1400 0.0300"/></geometry>
    </collision>
  </link>

  <ros2_control name="RehabExoSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      <!-- comanda de pozitie aplicata ca viteza = k * eroare; implicitul e prea mic -->
      <param name="position_proportional_gain">15.0</param>
    </hardware>
    <!-- left_hip: encoder absolut (position) + torque (effort); comanda pozitie+viteza -->
    <joint name="left_hip_joint">
      <command_interface name="position">
        <param name="min">-0.45</param>
        <param name="max">0.7</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- left_knee: encoder absolut (position) + torque (effort); comanda pozitie+viteza -->
    <joint name="left_knee_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">1.75</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- left_ankle: senzor de unghi (position) + torque (effort); comanda pozitie+viteza -->
    <joint name="left_ankle_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- right_hip: encoder absolut (position) + torque (effort); comanda pozitie+viteza -->
    <joint name="right_hip_joint">
      <command_interface name="position">
        <param name="min">-0.45</param>
        <param name="max">0.7</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- right_knee: encoder absolut (position) + torque (effort); comanda pozitie+viteza -->
    <joint name="right_knee_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">1.75</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- right_ankle: senzor de unghi (position) + torque (effort); comanda pozitie+viteza -->
    <joint name="right_ankle_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-2.0</param>
        <param name="max">2.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <!-- Axele de ajustare (prismatice): comanda pozitie, stare completa -->
    <joint name="seat_lift_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.15</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_thigh_ext_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.08</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_thigh_ext_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.08</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_shank_ext_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.08</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_shank_ext_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.08</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find rehab_exo_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
